{
  "name": "@limewire/lmwrntwrk-sdk-ts",
  "version": "0.1.2",
  "description": "S3-compatible LMWRNTWRK middleware and helpers for AWS SDK v3",
  "author": "LimeWire Network (https://limewire.network)",
  "license": "LGPL-2.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LimeWireOfficial/lmwrntwrk-sdk-ts.git"
  },
  "bugs": {
    "url": "https://github.com/LimeWireOfficial/lmwrntwrk-sdk-ts/issues"
  },
  "homepage": "https://github.com/LimeWireOfficial/lmwrntwrk-sdk-ts#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./src/index.js"
    }
  },
  "files": [
    "src",
    "dist/types",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "tsx --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json",
    "build:types": "tsc -p tsconfig.build.json",
    "build:js": "tsc -p tsconfig.build.json --emitDeclarationOnly false --noEmit false --outDir ./dist",
    "build": "rm -rf dist && npm run build:types && npm run build:js"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@noble/secp256k1": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
